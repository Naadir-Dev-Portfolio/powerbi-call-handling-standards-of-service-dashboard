	partition 'Fact Telephony' = m
		mode: import
		source =
				let
					Source = Csv.Document(File.Contents(CuratedDataFolder & "\fact_telephony.csv"), [Delimiter=",", Columns=27, Encoding=65001, QuoteStyle=QuoteStyle.Csv]),
					Headers = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),
					Typed = Table.TransformColumnTypes(
						Headers,
						{
							{"TelephonyRecordKey", Int64.Type},
							{"DateKey", Int64.Type},
							{"TimeSlotKey", Int64.Type},
							{"CallTypeKey", Int64.Type},
							{"TeamKey", Int64.Type},
							{"CallGroupKey", Int64.Type},
							{"QueueKey", Int64.Type},
							{"FunctionKey", Int64.Type},
							{"EmergencyClassKey", Int64.Type},
							{"WorkingHoursKey", Int64.Type},
							{"CallsOffered", Int64.Type},
							{"CallsAnswered", Int64.Type},
							{"CallsAbandonedAfterThreshold", Int64.Type},
							{"CallsAbandonedWithinThreshold", Int64.Type},
							{"RONA", Int64.Type},
							{"OverflowOut", Int64.Type},
							{"CallsRoutedNonAgent", Int64.Type},
							{"ShortCalls", Int64.Type},
							{"ServiceLevelCalls", Int64.Type},
							{"ServiceLevelCallsOffered", Int64.Type},
							{"WaitTimeSeconds", Int64.Type},
